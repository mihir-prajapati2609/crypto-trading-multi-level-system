# ============================================
# Crypto Arbitrage Bot — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# --- Binance ---
BINANCE_API_KEY=YOUR_KEY
BINANCE_API_SECRET=YOUR_KEY
# --- OKX (optional, for cross-exchange arbitrage) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Telegram Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Trading Parameters ---
# Minimum net profit threshold (after fees) to execute a trade (percentage)
MIN_PROFIT_THRESHOLD=0.15
# Maximum % of available balance per single trade
MAX_POSITION_PCT=30
# Maximum daily loss as % of total capital before auto-pause
DAILY_LOSS_LIMIT=2.0
# Z-score thresholds for mean reversion signals
Z_SCORE_ENTRY=2.0
Z_SCORE_EXIT=0.5
Z_SCORE_STOP=3.0

# --- Coin Discovery ---
# How often to re-scan for optimal coins (hours)
COIN_RESCAN_INTERVAL=6
# Number of top coins to keep in watchlist
WATCHLIST_SIZE=25

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_API_KEY=change_this_to_a_random_string

# --- Mode ---
# Set to 'paper' for paper trading, 'live' for real trading
TRADING_MODE=paper

# --- AI Event Intelligence ---
# Enable/disable the event intelligence engine
EVENT_INTELLIGENCE_ENABLED=true
# Mode: 'observe' = score only (no trades), 'trade' = score + execute paper trades
EVENT_INTELLIGENCE_MODE=observe
# Minimum AI confidence % to trigger a trade (when in 'trade' mode)
EVENT_MIN_CONFIDENCE=90
# Max position size as % of capital per event trade
EVENT_MAX_POSITION_PCT=3
# Maximum concurrent event-driven trades
EVENT_MAX_OPEN_TRADES=5
# Max daily loss % before event trading pauses
EVENT_MAX_DAILY_LOSS_PCT=3
# Max drawdown % before event trading pauses
EVENT_MAX_DRAWDOWN_PCT=10
# Optional: Etherscan API key for on-chain whale tracking
ETHERSCAN_API_KEY=
# Optional: GitHub token for monitoring repo activity
GITHUB_TOKEN=
